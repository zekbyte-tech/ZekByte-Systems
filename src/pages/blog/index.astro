---
import { Icon } from "astro-icon/components";
import { getCollection } from "astro:content";
import RootLayout from "../../layouts/RootLayout.astro";

const posts = (await getCollection("blog")).sort(
    (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf(),
);
const tags = Array.from(new Set(posts.flatMap((post) => post.data.tags)));
---

<RootLayout>
    <div class="bg-background min-h-screen">
        <div class="mx-auto max-w-5xl px-6 py-12">
            <section class="mb-12">
                <h1 class="mb-4">Articles</h1>
                <p class="text-muted-foreground max-w-2xl">
                    Browse through all articles covering web development,
                    DevOps, databases, and software engineering best practices.
                </p>
            </section>

            <div class="mb-8">
                <div
                    class="text-muted-foreground mb-3 flex items-center gap-2 text-sm"
                >
                    <Icon name="lucide:filter" class="h-4 w-4" />
                    Filter by topic:
                </div>
                <div class="flex flex-wrap gap-2">
                        <a
                            href=`/blog`
                            class:list={[
                                "rounded-md px-4 py-2 transition-colors",
                                {
                                    "bg-primary text-primary-foreground": true,
                                    "bg-muted hover:bg-muted/70": false,
                                },
                            ]}
                        >
                        All
                    </a>
                    {
                        tags.map((tag) => (
                            <a
                                href=`/tags/${tag}`
                                class:list={[
                                    "rounded-md px-4 py-2 transition-colors",
                                    {
                                        "bg-primary text-primary-foreground": false,
                                        "bg-muted hover:bg-muted/70": true,
                                    },
                                ]}
                            >
                                {tag}
                            </a>
                        ))
                    }
                </div>
            </div>

            {
                posts.length === 0 ? (
                    <div class="py-12 text-center">
                        <p class="text-muted-foreground">
                            No articles found matching your criteria.
                        </p>
                    </div>
                ) : (
                    <>
                        <div class="text-muted-foreground mb-6 text-sm">
                            Showing {posts.length}{" "}
                            {posts.length === 1 ? "article" : "articles"}
                        </div>

                        <div class="space-y-8">
                            {posts.map((post) => (
                                <a
                                    href={`/blog/${post.id}`}
                                    class="group block no-underline"
                                >
                                    <article class="border-border hover:border-foreground/20 bg-card overflow-hidden rounded-lg border transition-colors">
                                        <div class="grid gap-6 md:grid-cols-[300px_1fr]">
                                            <div class="bg-muted relative aspect-video overflow-hidden md:aspect-square">
                                                <img
                                                    src={`https://img.youtube.com/vi/${post.data.youtubeId}/maxresdefault.jpg`}
                                                    alt={post.data.title}
                                                    class="h-full w-full object-cover"
                                                />
                                            </div>
                                            <div class="p-6 md:py-6 md:pr-6 md:pl-0">
                                                <div class="text-muted-foreground mb-3 flex items-center gap-4 text-sm">
                                                    <time>
                                                        {new Date(
                                                            post.data
                                                                .publishedAt,
                                                        ).toLocaleDateString(
                                                            "en-US",
                                                            {
                                                                month: "long",
                                                                day: "numeric",
                                                                year: "numeric",
                                                            },
                                                        )}
                                                    </time>
                                                </div>
                                                <h2 class="group-hover:text-accent mb-3 transition-colors">
                                                    {post.data.title}
                                                </h2>
                                                <p class="text-muted-foreground m-0 mb-4">
                                                    {post.data.excerpt}
                                                </p>
                                                <div class="flex flex-wrap gap-2">
                                                    {post.data.tags.map(
                                                        (tag) => (
                                                            <span class="bg-muted text-muted-foreground rounded px-2 py-1 text-sm">
                                                                {tag}
                                                            </span>
                                                        ),
                                                    )}
                                                </div>
                                            </div>
                                        </div>
                                    </article>
                                </a>
                            ))}
                        </div>
                    </>
                )
            }
        </div>
    </div>
</RootLayout>
