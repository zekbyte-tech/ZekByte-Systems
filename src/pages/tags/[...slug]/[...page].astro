---
import { Icon } from "astro-icon/components";
import { getCollection } from "astro:content";

import RootLayout from "../../../layouts/RootLayout.astro";
import ArticleCardWide from "../../../components/components/article-card-wide.astro";

export async function getStaticPaths({ paginate }) {
  const posts = await getCollection("blog");

  const tags = Array.from(new Set(posts.flatMap((post) => post.data.tags)));

  return tags.flatMap((tag) => {
    const filteredPosts = posts
      .filter((post) => post.data.tags.includes(tag))
      .sort(
        (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf(),
      );

    return paginate(filteredPosts, {
      pageSize: 10,

      params: {
        slug: tag,
      },

      props: {
        tag,
        tags,
      },
    });
  });
}

const allPosts = await getCollection("blog");
const tags = Array.from(new Set(allPosts.flatMap((post) => post.data.tags)));

const { page } = Astro.props;
const { slug: currentTag } = Astro.params;
const posts = page.data;
---

<RootLayout title={currentTag}>
  <div class="bg-background min-h-screen">
    <div class="mx-auto max-w-5xl px-6 py-12">
      <section class="mb-12">
        <h1 class="mb-4">Articles</h1>

        <p class="text-muted-foreground max-w-2xl">
          Browse through all articles covering web development, DevOps,
          databases, and software engineering best practices.
        </p>
      </section>

      <!-- Tags -->

      <div class="mb-8">
        <div class="text-muted-foreground mb-3 flex items-center gap-2 text-sm">
          <Icon name="lucide:filter" class="h-4 w-4" />

          Filter by topic:
        </div>

        <div class="flex flex-wrap gap-2">
          <a
            href="/blog"
            class="bg-muted hover:bg-muted/70 rounded-md px-4 py-2 transition-colors"
          >
            All
          </a>

          {
            tags.map((tag) => (
              <a
                href={`/tags/${tag}`}
                class:list={[
                  "rounded-md px-4 py-2 transition-colors",
                  {
                    "bg-primary text-primary-foreground": currentTag === tag,

                    "bg-muted hover:bg-muted/70": currentTag !== tag,
                  },
                ]}
              >
                {tag}
              </a>
            ))
          }
        </div>
      </div>

      <!-- Count -->

      <div class="text-muted-foreground mb-6 text-sm">
        Showing {posts.length}{" "}
        {posts.length === 1 ? "article" : "articles"}
      </div>

      <!-- Posts -->

      <div class="space-y-8">
        {posts.map((post) => <ArticleCardWide post={post} />)}
      </div>

      <!-- Pagination -->

      <div class="mt-12 flex items-center justify-center gap-2">
        {
          page.url.prev && (
            <a
              href={page.url.prev}
              class="bg-muted hover:bg-muted/70 rounded-md px-4 py-2 no-underline transition-colors"
            >
              Previous
            </a>
          )
        }

        {
          Array.from({ length: page.lastPage }, (_, i) => i + 1).map(
            (pageNumber) => (
              <a
                href={
                  pageNumber === 1
                    ? `/tags/${currentTag}`
                    : `/tags/${currentTag}/${pageNumber}`
                }
                class:list={[
                  "rounded-md px-4 py-2 no-underline transition-colors",
                  {
                    "bg-primary text-primary-foreground":
                      pageNumber === page.currentPage,

                    "bg-muted hover:bg-muted/70":
                      pageNumber !== page.currentPage,
                  },
                ]}
              >
                {pageNumber}
              </a>
            ),
          )
        }

        {
          page.url.next && (
            <a
              href={page.url.next}
              class="bg-muted hover:bg-muted/70 rounded-md px-4 py-2 no-underline transition-colors"
            >
              Next
            </a>
          )
        }
      </div>
    </div>
  </div>
</RootLayout>
