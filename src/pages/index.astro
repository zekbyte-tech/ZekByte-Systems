---
import { getCollection, getEntry } from "astro:content";
import Banner from "../components/blocks/banner.astro";
import RecentPosts from "../components/blocks/recent-posts.astro";
import RootLayout from "../layouts/RootLayout.astro";

const home = await getEntry("home", "home");

const posts = (await getCollection("blog")).sort(
    (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf(),
);
---

<RootLayout>
    {home && home.data && home.data.banner && <Banner {...home.data.banner} />}
    {posts.length > 0 && <RecentPosts posts={posts} />}
</RootLayout>
