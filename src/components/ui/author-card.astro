---
const { author } = Astro.props;
const initials = author
    .split(" ")
    .slice(0, 2)
    .map((name: string) => name.split("").at(0));
---

<div class="flex items-center gap-3">
    <div
        class="bg-accent text-accent-foreground flex h-10 w-10 items-center justify-center rounded-full"
    >
        {initials}
    </div>
    <div>
        <div class="text-foreground">
            {author}
        </div>
    </div>
</div>
