---
import { Icon } from "astro-icon/components";

const { title, subtitle, label, href } = Astro.props;
---

<div class="border-border mb-12 border-y py-8">
    <div class="flex flex-col items-center justify-between gap-6 sm:flex-row">
        <div>
            <h4 class="mb-2">{title}</h4>
            <p class="text-muted-foreground m-0">
                {subtitle}
            </p>
        </div>
        <a
            href={href}
            target="_blank"
            rel="noopener noreferrer"
            class="bg-accent text-accent-foreground hover:bg-accent/90 inline-flex items-center gap-2 rounded-md px-6 py-3 whitespace-nowrap no-underline transition-colors"
        >
            <Icon name="lucide:youtube" class="h-5 w-5" />
            {label}
        </a>
    </div>
</div>
