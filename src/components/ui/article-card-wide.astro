---
import { Image } from "astro:assets";

const { post } = Astro.props;
const thumbnail = `https://img.youtube.com/vi/${post.data.youtubeId}/hqdefault.jpg`;
---

<a href={`/blog/${post.id}`} class="group block no-underline">
    <article
        class="border-border hover:border-foreground/20 bg-card overflow-hidden rounded-lg border transition-colors"
    >
        <div class="grid gap-6 md:grid-cols-[300px_1fr]">
            <div
                class="bg-muted relative aspect-video overflow-hidden md:aspect-square"
            >
                <Image
                    src={thumbnail}
                    alt={post.data.title || "Featured Image"}
                    width={480}
                    height={270}
                    widths={[320, 480, 640]}
                    sizes="(max-width: 768px) 100vw, 410px"
                    format="avif"
                    quality={80}
                    class="h-full w-full object-cover"
                    fetchpriority="high"
                    loading="eager"
                />
            </div>
            <div class="p-6 md:py-6 md:pr-6 md:pl-0">
                <div
                    class="text-muted-foreground mb-3 flex items-center gap-4 text-sm"
                >
                    <time>
                        {
                            new Date(post.data.publishedAt).toLocaleDateString(
                                "en-US",
                                {
                                    month: "long",
                                    day: "numeric",
                                    year: "numeric",
                                },
                            )
                        }
                    </time>
                </div>
                <h2 class="group-hover:text-accent mb-3 transition-colors">
                    {post.data.title}
                </h2>
                <p class="text-muted-foreground m-0 mb-4">
                    {post.data.excerpt}
                </p>
                <div class="flex flex-wrap gap-2">
                    {
                        post.data.tags.map((tag: string) => (
                            <span class="bg-bright text-bright-foreground rounded px-2 py-1 text-sm">
                                {tag}
                            </span>
                        ))
                    }
                </div>
            </div>
        </div>
    </article>
</a>
