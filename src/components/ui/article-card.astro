---
import { Icon } from "astro-icon/components";

const { post } = Astro.props;
---

<a href={`/blog/${post.id}`} class="group block no-underline">
    <article
        class="border-border hover:border-foreground/20 bg-card overflow-hidden rounded-lg border transition-colors"
    >
        <div class="bg-muted relative aspect-video">
            <img
                src={`https://img.youtube.com/vi/${post.data.youtubeId}/maxresdefault.jpg`}
                alt={post.data.title}
                class="h-full w-full object-cover"
            />
            <div
                class="absolute inset-0 flex items-center justify-center bg-black/50 opacity-0 transition-opacity group-hover:opacity-100"
            >
                <Icon name="lucide:youtube" class="h-12 w-12 text-white" />
            </div>
        </div>
        <div class="p-6">
            <div
                class="text-muted-foreground mb-3 flex items-center gap-4 text-sm"
            >
                <time
                    >{
                        new Date(post.data.publishedAt).toLocaleDateString(
                            "en-US",
                            {
                                month: "short",
                                day: "numeric",
                                year: "numeric",
                            },
                        )
                    }</time
                >
            </div>
            <h3 class="group-hover:text-bright mb-2 transition-colors">
                {post.data.title}
            </h3>
            <p class="text-muted-foreground m-0">{post.data.excerpt}</p>
            <div class="mt-4 flex flex-wrap gap-2">
                {
                    post.data.tags.map((tag: string) => (
                        <span class="bg-bright text-bright-foreground rounded px-2 py-1 text-sm">
                            {tag}
                        </span>
                    ))
                }
            </div>
        </div>
    </article>
</a>
