---
export interface Props {
    page: any;
    baseUrl: string;
    firstPageUrl?: any;
}

const { page, baseUrl, firstPageUrl } = Astro.props;
---

<div class="mt-12 flex items-center justify-center gap-2">
    {
        page.url.prev && (
            <a
                href={page.url.prev}
                class="bg-muted hover:bg-muted/70 rounded-md px-4 py-2 no-underline transition-colors"
            >
                Previous
            </a>
        )
    }

    {
        Array.from({ length: page.lastPage }, (_, i) => i + 1).map(
            (pageNumber) => (
                <a
                    href={
                        pageNumber === 1
                            ? firstPageUrl || baseUrl
                            : `${baseUrl}/${pageNumber}`
                    }
                    class:list={[
                        "rounded-md px-4 py-2 no-underline transition-colors",
                        {
                            "bg-primary text-primary-foreground":
                                pageNumber === page.currentPage,

                            "bg-muted hover:bg-muted/70":
                                pageNumber !== page.currentPage,
                        },
                    ]}
                >
                    {pageNumber}
                </a>
            ),
        )
    }

    {
        page.url.next && (
            <a
                href={page.url.next}
                class="bg-muted hover:bg-muted/70 rounded-md px-4 py-2 no-underline transition-colors"
            >
                Next
            </a>
        )
    }
</div>
