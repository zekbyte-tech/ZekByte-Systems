---
import { Icon } from "astro-icon/components";

const { posts, limit = 6 } = Astro.props;
---

<section class="bg-background">
    <div class="mx-auto max-w-5xl px-6 py-16">
        <div class="mb-8 flex items-center justify-between">
            <h2 class="m-0">Recent Articles</h2>
            <a
                href="/blog"
                class="text-accent flex items-center gap-1 no-underline hover:underline"
            >
                View all
                <Icon name="lucide:arrow-right" class="h-4 w-4" />
            </a>
        </div>
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            {
                posts.slice(0, limit).map((post) => (
                    <a
                        href={`/blog/${post.id}`}
                        class="group block no-underline"
                    >
                        <article class="border-border hover:border-foreground/20 bg-card h-full overflow-hidden rounded-lg border transition-colors">
                            <div class="bg-muted relative aspect-video">
                                <img
                                    src={`https://img.youtube.com/vi/${post.data.youtubeId}/maxresdefault.jpg`}
                                    alt={post.data.title}
                                    class="h-full w-full object-cover"
                                />
                            </div>
                            <div class="p-4">
                                <div class="text-muted-foreground mb-2 flex items-center gap-3 text-sm">
                                    <time>
                                        {new Date(
                                            post.data.publishedAt,
                                        ).toLocaleDateString("en-US", {
                                            month: "short",
                                            day: "numeric",
                                        })}
                                    </time>
                                </div>
                                <h3 class="group-hover:text-accent mb-2 transition-colors">
                                    {post.data.title}
                                </h3>
                            </div>
                        </article>
                    </a>
                ))
            }
        </div>
    </div>
</section>
