---
import { Icon } from "astro-icon/components";

const today = new Date();
---

<footer class="border-border bg-background mt-24 border-t">
    <div class="mx-auto max-w-5xl px-6 py-12">
        <div class="flex flex-col justify-between gap-8 md:flex-row">
            <div class="flex flex-col gap-4">
                <h3 class="m-0">TechBlog</h3>
                <p class="text-muted-foreground m-0 max-w-md">
                    In-depth technical articles, tutorials, and YouTube content
                    about web development, DevOps, and modern technology.
                </p>
            </div>

            <div class="flex flex-col gap-4">
                <h4 class="m-0">Connect</h4>
                <div class="flex gap-4">
                    <a
                        href="https://youtube.com"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-foreground/70 hover:text-accent transition-colors"
                        aria-label="YouTube"
                    >
                        <Icon name="lucide:youtube" class="h-5 w-5" />
                    </a>
                    <a
                        href="https://twitter.com"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-foreground/70 hover:text-accent transition-colors"
                        aria-label="Twitter"
                    >
                        <Icon name="lucide:twitter" class="h-5 w-5" />
                    </a>
                    <a
                        href="https://github.com"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-foreground/70 hover:text-accent transition-colors"
                        aria-label="GitHub"
                    >
                        <Icon name="lucide:github" class="h-5 w-5" />
                    </a>
                    <a
                        href="/rss.xml"
                        class="text-foreground/70 hover:text-accent transition-colors"
                        aria-label="RSS Feed"
                    >
                        <Icon name="lucide:rss" class="h-5 w-5" />
                    </a>
                </div>
            </div>
        </div>

        <div
            class="border-border text-muted-foreground mt-8 border-t pt-8 text-center"
        >
            <p class="m-0">
                © {today.getFullYear()} TechBlog. All rights reserved.
            </p>
        </div>
    </div>
</footer>
