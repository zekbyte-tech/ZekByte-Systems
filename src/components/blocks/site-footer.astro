---
import { Icon } from "astro-icon/components";
import type { CollectionEntry } from "astro:content";

type Site = CollectionEntry<"site">;

interface Props {
    site?: Site;
}

const { site } = Astro.props;
---

<footer class="border-border bg-background mt-24 border-t">
    <div class="mx-auto max-w-5xl px-6 py-12">
        <div class="flex flex-col justify-between gap-8 md:flex-row">
            <div class="flex flex-col gap-4">
                <h3 class="m-0">{site?.data.footer.title}</h3>
                <p class="text-muted-foreground m-0 max-w-md">
                    {site?.data.footer.description}
                </p>
            </div>

            <div class="flex flex-col gap-4">
                <h4 class="m-0">Connect</h4>
                <div class="flex gap-4">
                    {
                        site?.data.social.main.map((social) => (
                            <a
                                href={social.href}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="text-foreground/70 hover:text-accent transition-colors"
                                aria-label={social.name}
                            >
                                <Icon name=`${social.icon}` class="h-5 w-5" />
                            </a>
                        ))
                    }
                    <a
                        href="/rss.xml"
                        class="text-foreground/70 hover:text-accent transition-colors"
                        aria-label="RSS Feed"
                    >
                        <Icon name="lucide:rss" class="h-5 w-5" />
                    </a>
                </div>
            </div>
        </div>

        <div
            class="text-muted-foreground mt-8 pt-8 text-center text-sm"
        >
            <p class="m-0">
                {site?.data.footer.copyright}
            </p>
        </div>
    </div>
</footer>
