---
import { Icon } from "astro-icon/components";

const { title, description, buttons } = Astro.props;
---

<section class="border-border bg-muted/30 border-b">
  <div class="mx-auto max-w-5xl px-6 py-24">
    <div class="max-w-3xl">
      <h1 class="mb-6 tracking-tight">{title}</h1>
      <p class="text-muted-foreground mb-8 max-w-2xl leading-relaxed">
        {description}
      </p>
      <div class="flex flex-wrap gap-4">
        {
          buttons.primary && (
            <a
              href={buttons.primary.href}
              class="bg-primary text-primary-foreground hover:bg-primary/90 inline-flex items-center gap-2 rounded-md px-6 py-3 no-underline transition-colors"
            >
              {buttons.primary.label}
              <Icon name={buttons.primary.icon} class="h-4 w-4" />
            </a>
          )
        }
        {
          buttons.secondary && (
            <a
              href={buttons.secondary.href}
              target="_blank"
              rel="noopener noreferrer"
              class="border-border hover:bg-muted text-foreground inline-flex items-center gap-2 rounded-md border px-6 py-3 no-underline transition-colors"
            >
              <Icon name={buttons.secondary.icon} class="h-4 w-4" />
              {buttons.secondary.label}
            </a>
          )
        }
      </div>
    </div>
  </div>
</section>
